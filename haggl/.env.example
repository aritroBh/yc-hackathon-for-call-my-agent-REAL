# ── Supabase ─────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Khaya AI (GhanaNLP) — STT + TTS ──────
# Subscription key (sent as Ocp-Apim-Subscription-Key). ASR/TTS need Standard tier.
KHAYA_API_KEY=
KHAYA_BASE_URL=https://translation-api.ghananlp.org
# TTS v2 speaker (GET /tts/v2/speakers): male_low | male_high | female
KHAYA_TTS_SPEAKER_ID=male_low
# ASR v3 code (GET /asr/v3/languages): tw | dag | ee
KHAYA_ASR_LANGUAGE=tw
# TTS v2 code (GET /tts/v2/languages): Asante Twi = twi (Akuapem = atw)
KHAYA_TTS_LANGUAGE=twi
# Generic/translation code (GET /v2/languages): tw
KHAYA_LANGUAGE=tw

# ── Vapi — voice orchestration ───────────
VAPI_API_KEY=
VAPI_BASE_URL=https://api.vapi.ai
# Pre-imported Twilio/Vonage/Telnyx number id (needed for West-African dialing)
VAPI_PHONE_NUMBER_ID=
# Public WSS URL of the express-bridge (Vapi custom-transcriber connects here).
# In dev: ngrok http 3001  →  wss://<host>
BRIDGE_PUBLIC_WS_URL=wss://localhost:3001

# ── Anthropic ────────────────────────────
ANTHROPIC_API_KEY=


# ── Encryption ───────────────────────────
ENCRYPTION_KEY=

# ── Server ───────────────────────────────
SERVER_PORT=3001
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000
DEMO_MODE=false
NEXT_PUBLIC_DEMO_ORG_ID=00000000-0000-0000-0000-000000000001

# Sponsors
MOSS_PROJECT_ID=
MOSS_PROJECT_KEY=
SUPERMEMORY_API_KEY=
AGENTMAIL_API_KEY=
AGENTMAIL_INBOX=
BUYER_NOTIFICATION_EMAIL=
SPONGE_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
BROWSER_USE_API_KEY=
