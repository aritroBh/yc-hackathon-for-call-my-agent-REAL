{
  "name": "haggl",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:migrate": "node db/migrate.mjs",
    "db:seed": "node db/seed.mjs",
    "server": "tsx workers/express-bridge.mjs",
    "dev:all": "concurrently \"npm run dev\" \"npm run server\"",
    "test:stress": "tsx scripts/stress-test.ts",
    "test:concurrency": "tsx scripts/concurrency-test.ts",
    "worker": "tsx workers/callWorker.ts",
    "rl:run": "tsx workers/rlWorker.ts",
    "rl:dry": "tsx workers/rlWorker.ts --dry-run",
    "rl:replay": "tsx scripts/manual-rl-replay.ts",
    "rl:cron": "node cron/schedule.js run",
    "docker:build": "docker build -t haggl .",
    "docker:run": "docker compose up",
    "seed:demo": "tsx scripts/generate-seed.ts",
    "seed:memory": "tsx scripts/seed-supermemory.ts",
    "seed:check": "curl -X POST http://localhost:3000/api/supermemory/seed",
    "validate:env": "tsx -e \"require('./lib/env').validateEnv()\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "@google/genai": "^2.3.0",
    "@moss-dev/moss": "^1.0.2",
    "@supabase/ssr": "^0.5.0",
    "@supabase/supabase-js": "^2.45.0",
    "axios": "^1.16.1",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "express-ws": "^5.0.2",
    "next": "14.2.35",
    "papaparse": "^5.5.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "socket.io": "^4.8.0",
    "socket.io-client": "^4.8.0",
    "stripe": "^22.1.1",
    "supermemory": "^4.21.1",
    "uuid": "^10.0.0",
    "ws": "^8.18.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.17.0",
    "@types/papaparse": "^5.2.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.12",
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.1.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.35",
    "postcss": "^8.4.0",
    "prettier": "^3.4.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
