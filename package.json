{
  "name": "haggl",
  "version": "0.1.0",
  "scripts": {
    "dev": "concurrently \"next dev -p 3000\" \"ts-node-dev --respawn --transpile-only server/index.ts\"",
    "build": "next build && tsc --project tsconfig.server.json",
    "start": "concurrently \"next start\" \"node dist/server/index.js\"",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "db:migrate": "node -e \"require('./db/migrate')\"",
    "db:seed": "node -e \"require('./db/seed')\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.37.0",
    "@deepgram/sdk": "^3.9.0",
    "@google/genai": "^2.3.0",
    "@supabase/ssr": "^0.5.0",
    "@supabase/supabase-js": "^2.105.0",
    "axios": "^1.7.0",
    "concurrently": "^9.0.0",
    "cors": "^2.8.6",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "express-ws": "^5.0.2",
    "next": "14.2.0",
    "papaparse": "^5.4.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "socket.io": "^4.7.0",
    "socket.io-client": "^4.7.0",
    "twilio": "^5.4.0",
    "ws": "^8.18.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-ws": "^3.0.4",
    "@types/node": "^20.0.0",
    "@types/papaparse": "^5.3.14",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.5.12",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.0"
  }
}
