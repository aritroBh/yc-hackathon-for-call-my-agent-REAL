# Copy to .env.local and fill in. .env.local is gitignored.

# Gemini powers the chat agent (server-side only, via /api/chat).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Fast draft model for the agent-proposed sourcing plan and refinements
# (/api/plan/generate, /api/plan/refine). Defaults to gemini-3.1-flash-lite.
GEMINI_PLAN_MODEL=gemini-3.1-flash-lite

# Headless haggl backend. The /api/plan/research proxy calls
# `${HAGGL_API_URL}/api/research` (Gemini Deep Research) server-to-server.
# haggl's `next dev` serves on :3000. Must be reachable from web/.
HAGGL_API_URL=http://localhost:3000

# Sign-the-deal flow (server-side only, via /api/deal/sign).
# Sponge autonomously settles the chosen deal. Without a key the deal is
# still recorded locally so the dashboard flow always completes.
SPONGE_API_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# AgentMail sends the buyer the payment receipt. Without these the
# payment still confirms in the UI, just no email goes out.
AGENTMAIL_API_KEY=
AGENTMAIL_INBOX=
# Receipt recipient (the buyer). Falls back to djnintang@gmail.com.
BUYER_NOTIFICATION_EMAIL=
